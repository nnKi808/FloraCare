<?xml version="1.0" encoding="utf-8"?>
<!--
    Registrierungs-Screen Layout.
    ScrollView außen: Auf kleinen Bildschirmen (oder bei eingeblendeter
    Tastatur) bleibt das Formular vollständig erreichbar.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/flora_hintergrund"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_titel"
            android:textColor="@color/flora_gruen"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:text="@string/register_untertitel"
            android:textColor="@color/flora_text_dunkel"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/input_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:autofillHints="name"
            android:hint="@string/hint_name"
            android:inputType="textPersonName"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints="emailAddress"
            android:hint="@string/hint_email"
            android:inputType="textEmailAddress"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_passwort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints="newPassword"
            android:hint="@string/hint_passwort_mind"
            android:inputType="textPassword"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_passwort_wdh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autofillHints="newPassword"
            android:hint="@string/hint_passwort_wdh"
            android:inputType="textPassword"
            android:minHeight="48dp" />

        <Button
            android:id="@+id/button_registrieren"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/flora_gruen"
            android:minHeight="52dp"
            android:text="@string/button_konto_erstellen"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/lade_anzeige"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/link_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="48dp"
            android:gravity="center"
            android:text="@string/link_zum_login"
            android:textColor="@color/flora_gruen"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
