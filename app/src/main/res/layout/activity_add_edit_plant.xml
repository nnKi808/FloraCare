<?xml version="1.0" encoding="utf-8"?>
<!--
    Formular zum Anlegen/Bearbeiten einer Pflanze.
    Derselbe Screen für beide Modi: Titel und Löschen-Button werden vom Code
    je nach Modus gesetzt bzw. ein-/ausgeblendet.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/flora_hintergrund"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/text_titel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColor="@color/flora_gruen"
            android:textSize="24sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/input_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_plant_name"
            android:inputType="text"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_art"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_plant_species"
            android:inputType="text"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_besitzer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_plant_owner"
            android:inputType="text"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_giessen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_plant_water"
            android:inputType="number"
            android:minHeight="48dp" />

        <EditText
            android:id="@+id/input_duengen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_plant_fertilize"
            android:inputType="number"
            android:minHeight="48dp" />

        <Button
            android:id="@+id/button_speichern"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/flora_gruen"
            android:minHeight="52dp"
            android:text="@string/button_speichern"
            android:textSize="16sp" />

        <Button
            android:id="@+id/button_loeschen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#C62828"
            android:minHeight="48dp"
            android:text="@string/button_pflanze_loeschen"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/lade_anzeige"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
