<?xml version="1.0" encoding="utf-8"?>
<!--
    Dashboard Layout - Stand Etappe 3.
    Neu gegenüber Etappe 2: Button "Meine Pflanzen" (führt zur Pflanzenliste).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/flora_hintergrund"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_titel_logo"
        android:textColor="@color/flora_gruen"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_willkommen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/willkommen_laedt"
        android:textColor="@color/flora_text_dunkel"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/text_familie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text=""
        android:textColor="@color/flora_text_dunkel"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/text_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="@color/flora_gruen"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/button_meine_pflanzen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/flora_gruen"
        android:minHeight="52dp"
        android:paddingHorizontal="24dp"
        android:text="@string/button_meine_pflanzen"
        android:textSize="16sp" />

    <Button
        android:id="@+id/button_logout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:backgroundTint="@color/flora_gruen_hell"
        android:minHeight="44dp"
        android:text="@string/button_logout"
        android:textColor="@color/flora_text_dunkel" />

</LinearLayout>
